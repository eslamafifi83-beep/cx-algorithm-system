# --- The CX Algorithm — environment variables ---
# Copy this file to ".env" and fill in the real values.
# NEVER commit the real .env file (it's already git-ignored).

# From Supabase → Project Settings → Data API / API Keys
SUPABASE_URL=https://fuuuhcvwlrfenjfpcymy.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# The SECRET key (sb_secret_...). Server-side only. Keep private.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxx

# Admin login for the /admin panel — choose your own strong values
ADMIN_USER=admin
ADMIN_PASSWORD=choose-a-strong-password

# Optional: lets the admin auto-fill an episode from a Spotify link.
# From https://developer.spotify.com/dashboard → create an app → copy these.
# Without them, auto-fill still returns the title + cover (via public oEmbed).
SPOTIFY_CLIENT_ID=xxxxxxxxxxxxxxxx
SPOTIFY_CLIENT_SECRET=xxxxxxxxxxxxxxxx
